  <script is:inline define:vars={{ installJoined }}>
    (function () {
      // ── Copy install ────────────────────────────────
      var btn = document.getElementById('install-copy-btn');
      var label = document.getElementById('install-copy-label');
      if (btn) {
        btn.addEventListener('click', function () {
          navigator.clipboard.writeText(installJoined).then(function () {
            var orig = label.textContent;
            label.textContent = 'Copied!';
            if (window.trackEvent) window.trackEvent('copy_command', 'engagement', 'home_install');
            setTimeout(function () { label.textContent = orig; }, 1500);
          });
        });
      }

      // ── Animated beam ───────────────────────────────
      var wrap = document.getElementById('flow-wrap');
      var svg = document.getElementById('flow-svg');
      var center = document.getElementById('flow-center');
      var sources = document.querySelectorAll('#flow-sources .flow-source');
      var products = document.querySelectorAll('#flow-products .flow-product');
      if (!wrap || !svg || !center || !sources.length || !products.length) return;

      var SVG_NS = 'http://www.w3.org/2000/svg';
      var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      var beamElements = []; // {path, fromEl, toEl, dir} for hover highlighting
      var particles = [];    // {el, path, len, t, speed}
      var rafId = null;
      var lastFrame = 0;
      var paused = false;

      function centerOf(el, wrapRect) {
        var r = el.getBoundingClientRect();
        return {
          x: r.left - wrapRect.left + r.width / 2,
          y: r.top  - wrapRect.top  + r.height / 2,
        };
      }
      function edgePoint(el, wrapRect, side) {
        var r = el.getBoundingClientRect();
        var y = r.top - wrapRect.top + r.height / 2;
        if (side === 'right') return { x: r.right - wrapRect.left, y: y };
        return { x: r.left - wrapRect.left, y: y };
      }
      function makePath(from, to) {
        // Cubic with horizontal tangent control points — clean Magic-UI-style curve.
        var dx = to.x - from.x;
        var c1x = from.x + dx * 0.45;
        var c2x = from.x + dx * 0.55;
        return 'M ' + from.x + ' ' + from.y +
               ' C ' + c1x + ' ' + from.y + ', ' + c2x + ' ' + to.y + ', ' + to.x + ' ' + to.y;
      }

      function rebuild() {
        // Clear previous beams + particles. Use class selectors so polygon arrows
        // (added for outgoing beams) are also removed alongside circle particles.
        Array.prototype.slice.call(svg.querySelectorAll('.flow-beam, .flow-particle')).forEach(function (n) { n.remove(); });
        beamElements = [];
        particles = [];

        var wrapRect = wrap.getBoundingClientRect();
        var centerRight = edgePoint(center, wrapRect, 'right');
        var centerLeft  = edgePoint(center, wrapRect, 'left');
        // Center has its own ring; tie beams to the visual center, not the bounding box edge.
        var centerC = centerOf(center, wrapRect);
        var ringR = 92; // matches .flow-center-ring radius (180px disc) + a touch for the halo
        centerLeft  = { x: centerC.x - ringR, y: centerC.y };
        centerRight = { x: centerC.x + ringR, y: centerC.y };

        // Source → center beams
        sources.forEach(function (el) {
          var from = edgePoint(el, wrapRect, 'right');
          // Aim each source at the ring perimeter, not the dead center, for cleaner visuals
          var to = centerLeft;
          var path = document.createElementNS(SVG_NS, 'path');
          path.setAttribute('class', 'flow-beam');
          path.setAttribute('d', makePath(from, to));
          svg.appendChild(path);
          beamElements.push({ path: path, fromEl: el, toEl: center, dir: 'in' });
        });

        // Center → product beams
        products.forEach(function (el) {
          var from = centerRight;
          var to = edgePoint(el, wrapRect, 'left');
          var path = document.createElementNS(SVG_NS, 'path');
          path.setAttribute('class', 'flow-beam');
          path.setAttribute('d', makePath(from, to));
          svg.appendChild(path);
          beamElements.push({ path: path, fromEl: center, toEl: el, dir: 'out' });
        });

        // Set viewBox to wrap size
        svg.setAttribute('viewBox', '0 0 ' + wrapRect.width + ' ' + wrapRect.height);
        svg.setAttribute('width', wrapRect.width);
        svg.setAttribute('height', wrapRect.height);

        if (prefersReduced) return;

        var groupColors = {
          agent:    { fill: 'var(--accent-blue)', rgb: 'var(--accent-blue-rgb)' },
          provider: { fill: 'var(--green)',       rgb: 'var(--green-rgb)' },
          obs:      { fill: 'var(--amber)',       rgb: '245, 166, 35' },
        };

        // Spawn one particle per beam, staggered, with slightly varied speeds.
        beamElements.forEach(function (beam, i) {
          var p, isArrow = false;
          if (beam.dir === 'in') {
            // Source → TokenJam: circle, colored to match the source tile.
            var group = beam.fromEl.getAttribute('data-group') || 'agent';
            var c = groupColors[group] || groupColors.agent;
            p = document.createElementNS(SVG_NS, 'circle');
            p.setAttribute('class', 'flow-particle');
            p.setAttribute('r', '2.4');
            p.style.fill = c.fill;
            p.style.filter = 'drop-shadow(0 0 4px rgba(' + c.rgb + ', 0.85))';
          } else {
            // TokenJam → product: green arrow, oriented along the path.
            isArrow = true;
            p = document.createElementNS(SVG_NS, 'polygon');
            p.setAttribute('class', 'flow-particle flow-particle--arrow');
            p.setAttribute('points', '-3.5,-3 4.5,0 -3.5,3');
            p.style.fill = 'var(--green)';
            p.style.filter = 'drop-shadow(0 0 4px rgba(var(--green-rgb), 0.85))';
          }
          svg.appendChild(p);
          var len = beam.path.getTotalLength();
          // Stagger initial t so the flow looks ambient, not synchronized.
          var t0 = (i * 0.137 + Math.random() * 0.6) % 1;
          var speed = 0.00018 + Math.random() * 0.00008; // fraction per ms
          particles.push({ el: p, path: beam.path, len: len, t: t0, speed: speed, isArrow: isArrow });
        });
      }

      function animate(now) {
        if (paused || prefersReduced) { rafId = requestAnimationFrame(animate); return; }
        var dt = lastFrame ? (now - lastFrame) : 16;
        lastFrame = now;
        particles.forEach(function (pt) {
          pt.t += pt.speed * dt;
          if (pt.t > 1) pt.t -= 1;
          var s = pt.t * pt.len;
          var pos = pt.path.getPointAtLength(s);
          // Fade in/out at the ends so particles don't pop.
          var alpha = pt.t < 0.08 ? pt.t / 0.08 : (pt.t > 0.92 ? (1 - pt.t) / 0.08 : 1);
          if (pt.isArrow) {
            // Compute path tangent for arrow rotation.
            var ahead = pt.path.getPointAtLength(Math.min(s + 1.5, pt.len));
            var ang = Math.atan2(ahead.y - pos.y, ahead.x - pos.x) * 180 / Math.PI;
            pt.el.setAttribute('transform', 'translate(' + pos.x.toFixed(2) + ',' + pos.y.toFixed(2) + ') rotate(' + ang.toFixed(2) + ')');
          } else {
            pt.el.setAttribute('cx', pos.x);
            pt.el.setAttribute('cy', pos.y);
          }
          pt.el.setAttribute('opacity', alpha.toFixed(2));
        });
        rafId = requestAnimationFrame(animate);
      }

      function start() {
        if (rafId) cancelAnimationFrame(rafId);
        lastFrame = 0;
        rafId = requestAnimationFrame(animate);
      }

      // Pause when off-screen
      if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) { paused = !e.isIntersecting; });
        }, { threshold: 0.05 });
        io.observe(wrap);
      }

      // Hover highlights — light up beams touching the hovered node
      function highlightFor(el) {
        beamElements.forEach(function (b) {
          var match = b.fromEl === el || b.toEl === el;
          b.path.classList.toggle('is-active', match);
        });
      }
      function clearHighlight() {
        beamElements.forEach(function (b) { b.path.classList.remove('is-active'); });
      }
      [].slice.call(sources).concat([].slice.call(products)).concat([center]).forEach(function (el) {
        el.addEventListener('mouseenter', function () { highlightFor(el); });
        el.addEventListener('mouseleave', clearHighlight);
        el.addEventListener('focusin',  function () { highlightFor(el); });
        el.addEventListener('focusout', clearHighlight);
      });

      // Resize handling
      var rzTimer;
      window.addEventListener('resize', function () {
        clearTimeout(rzTimer);
        rzTimer = setTimeout(function () { rebuild(); }, 120);
      });

      // First paint: wait a tick for fonts/layout to settle so measurements are correct.
      requestAnimationFrame(function () {
        rebuild();
        start();
      });
      // Re-measure once webfonts finish loading (Geist arrives after first paint and shifts text by a few px).
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(function () { rebuild(); });
      }
    })();
  </script>
</BaseLayout>
