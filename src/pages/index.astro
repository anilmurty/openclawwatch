---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { products as productCatalog } from '@/data/products';

// Per-product accents (single source of truth lives in src/data/products.ts).
const accentBySlug = Object.fromEntries(
  productCatalog.map((p) => [p.slug, { accent: p.accent, accentRgb: p.accentRgb }])
);

// Source integrations shown in the hero beam (compact set — the works-with strip below covers the full list).
// `mark` is a short letter monogram used as a placeholder logo chip until official brand SVGs land.
const heroSources = [
  { id: 'claude-code',   name: 'Claude Code',   group: 'agent',    mark: 'CC' },
  { id: 'codex-cli',     name: 'Codex CLI',     group: 'agent',    mark: '>_' },
  { id: 'openai-agents', name: 'OpenAI Agents', group: 'agent',    mark: 'OA' },
  { id: 'langgraph',     name: 'LangGraph',     group: 'agent',    mark: 'LG' },
  { id: 'anthropic',     name: 'Anthropic',     group: 'provider', mark: 'A'  },
  { id: 'openai',        name: 'OpenAI',        group: 'provider', mark: 'O'  },
  { id: 'langfuse',      name: 'Langfuse',      group: 'obs',      mark: 'λ'  },
  { id: 'otlp',          name: 'OTLP',          group: 'obs',      mark: '◉'  },
];

// Full integration list shown in the works-with strip.
const allIntegrations = [
  'Claude Code', 'Codex CLI', 'OpenClaw', 'OpenAI Agents SDK', 'Google ADK',
  'Strands Agent SDK', 'LlamaIndex', 'Haystack', 'Pydantic AI', 'Semantic Kernel',
  'LangChain', 'LangGraph', 'CrewAI', 'AutoGen', 'NemoClaw',
  'Anthropic', 'OpenAI', 'Google Gemini', 'AWS Bedrock', 'LiteLLM',
  'Langfuse', 'Helicone', 'LangSmith', 'Phoenix', 'ccusage', 'OTLP',
];

const productsRaw = [
  {
    slug: 'downsize',
    name: 'Downsize',
    blurb: 'Find tasks where a cheaper model would suffice.',
    output: [
      { t: '$ tj optimize',                                                                  c: 'cmd'    },
      { t: '',                                                                                c: 'blank'  },
      { t: 'Analyzing 247 sessions, 9.8K spans, 4.0M tokens (last 30d)…',                     c: 'dim'    },
      { t: '',                                                                                c: 'blank'  },
      { t: '  ① Model downgrade: 47% of sessions look Haiku-eligible',                        c: 'label'  },
      { t: '     • 116 of 247 sessions match structural heuristics',                          c: 'val'    },
      { t: '     • Currently: claude-opus-4-7, claude-sonnet-4-7',                            c: 'val'    },
      { t: '     • Suggested target: claude-haiku-4-5',                                       c: 'val'    },
      { t: '     • At current usage: $1,886 → $254 (-86% on flagged sessions)',               c: 'success'},
      { t: '     • Estimated monthly savings: $1,632 (-38% total)',                           c: 'success'},
      { t: '',                                                                                c: 'blank'  },
      { t: '     ⚠ Structural heuristic only. Run `tj optimize --validate`',                  c: 'warn'   },
      { t: '       to replay-test on your actual sessions before applying.',                  c: 'warn'   },
    ],
  },
  {
    slug: 'trim',
    name: 'Trim',
    blurb: 'Identify token waste in your system prompts.',
    output: [
      { t: 'Prompt bloat detected in claude-code-myproj:',                                    c: 'label'  },
      { t: '  • Your CLAUDE.md is 4,213 tokens (up 38% in 30 days)',                          c: 'val'    },
      { t: '  • Section "Coding conventions > Error handling" appears identically',           c: 'val'    },
      { t: '    in 91 of 247 sessions (1,108 tokens × 91 = ~100K repeated tokens)',           c: 'val'    },
      { t: '  • Significance analysis suggests ~340 of those 1,108 tokens carry',             c: 'val'    },
      { t: '    the signal; the rest could be trimmed',                                       c: 'val'    },
      { t: '  • Estimated cost: ~$8.50/mo at current usage on Sonnet',                        c: 'success'},
      { t: '',                                                                                c: 'blank'  },
      { t: '  Detail: open `tj report --bloat claude-code-myproj` to see the',                c: 'dim'    },
      { t: '  highlighted prompt with high-significance tokens bold,',                        c: 'dim'    },
      { t: '  low-significance dimmed.',                                                      c: 'dim'    },
    ],
  },
  {
    slug: 'cache',
    name: 'Cache',
    blurb: 'Detect cacheable prompt prefixes. Save 30–60% with provider-native caching.',
    output: [
      { t: 'Cache opportunities in last 30d:',                                                c: 'label'  },
      { t: '  • Identical 2,400-token prefix detected across 94% of your calls',              c: 'val'    },
      { t: '    (your CLAUDE.md + tools + system prompt)',                                    c: 'val'    },
      { t: '  → You\'re already using prompt caching for 11% of cacheable opportunities.',    c: 'dim'    },
      { t: '  → Increasing cache_control breakpoints could save ~$42/mo (90% reduction',      c: 'success'},
      { t: '     on the 89% of calls currently paying full price).',                          c: 'success'},
      { t: '  → See `tj report --cache claude-code-myproj` for the specific config.',         c: 'dim'    },
      { t: '',                                                                                c: 'blank'  },
      { t: '  • Semantic similarity ≥0.95 detected on 47 instances of "format SQL query"',    c: 'val'    },
      { t: '    style requests in last 30d.',                                                 c: 'val'    },
      { t: '  → Estimated savings: $8/mo at TTL ≥ 1 day.',                                    c: 'success'},
    ],
  },
  {
    slug: 'script',
    name: 'Script',
    blurb: 'Surface recurring agent sessions that should have been simple (deterministic) scripts.',
    output: [
      { t: 'Deterministic workflow candidates (high confidence only):',                       c: 'label'  },
      { t: '  • 23 sessions in last 30d executed identical 5-step sequence:',                 c: 'val'    },
      { t: '    git pull → npm install → cat .env.staging → npm run build → pm2 restart',     c: 'val'    },
      { t: '',                                                                                c: 'blank'  },
      { t: '    Zero argument variation. Zero observed branching.',                           c: 'dim'    },
      { t: '    Estimated current cost: ~$87/mo (23 sessions × ~$3.80 average)',              c: 'val'    },
      { t: '',                                                                                c: 'blank'  },
      { t: '  → This looks like a deployment script, not an agent task.',                     c: 'dim'    },
      { t: '    Suggested: replace with `scripts/deploy-staging.sh`.',                        c: 'dim'    },
      { t: '    Estimated savings: $87/mo, plus ~30s latency per execution.',                 c: 'success'},
    ],
  },
];

// Decorate each product with its accent color from the data catalog.
const products = productsRaw.map((p) => ({
  ...p,
  accent: accentBySlug[p.slug]?.accent ?? '#ededed',
  accentRgb: accentBySlug[p.slug]?.accentRgb ?? '237, 237, 237',
}));

const installLines = [
  'pip install "tokenjam[mcp]"',
  'tj onboard --claude-code',
  'tj optimize',
];
const installJoined = installLines.join('\n');
---
<BaseLayout
  title="TokenJam — the optimization layer for AI agents"
  description="TokenJam reads your agent's telemetry and tells you what to downsize, where to trim prompts, and what to cache. Open-source. Runs locally."
  image="/og-image.png"
  wide
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-copy">
        <h1 class="hero-h1">The optimization layer for AI agents.</h1>
        <p class="hero-sub">
          TokenJam reads your agent's telemetry and tells you what to downsize,
          where to trim prompts, what to cache, and what to script.
        </p>
        <p class="hero-sub hero-sub-faint">Open-source. Runs locally.</p>
        <div class="hero-ctas">
          <a href="#install" class="btn-primary btn-lg" onclick="window.trackEvent && window.trackEvent('cta_click', 'conversion', 'get_started_hero')">Get started</a>
          <a href="https://github.com/metabuilder-labs/tokenjam" target="_blank" rel="noopener noreferrer" class="btn-secondary btn-lg" onclick="window.trackEvent && window.trackEvent('cta_click', 'conversion', 'view_on_github_hero')">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            View on GitHub
          </a>
        </div>
      </div>

      <!-- Animated flow -->
      <div class="flow-wrap" id="flow-wrap" aria-label="TokenJam ingests agent telemetry from many sources and emits four optimization analyzers">
        <div class="flow-grid">
          <!-- Sources column -->
          <ul class="flow-sources" id="flow-sources">
            {heroSources.map((s) => (
              <li class="flow-node flow-source" data-id={s.id} data-group={s.group}>
                <span class="flow-source-mark" aria-hidden="true">{s.mark}</span>
                <span class="flow-source-name">{s.name}</span>
              </li>
            ))}
          </ul>

          <!-- TokenJam center -->
          <div class="flow-center" id="flow-center" aria-label="TokenJam">
            <div class="flow-center-ring"></div>
            <div class="flow-center-label">
              <svg class="flow-center-mark" viewBox="65 35 110 130" fill="none" stroke="currentColor" stroke-width="8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="74" y="44" width="92" height="20" rx="6" ry="6" />
                <path d="M 104 72 L 74 72 L 74 152 L 104 152" />
                <path d="M 136 72 L 166 72 L 166 152 L 136 152" />
                <!-- W weight-matrix inside the jar (matches the wordmark Logo) -->
                <g fill="currentColor" stroke="none" fill-rule="evenodd">
                  <path transform="translate(85.68,104)" d="M21.19,-14.32 L16.75,-0.00 L13.63,-0.00 L10.74,-10.58 L7.85,-0.00 L4.73,-0.00 L0.26,-14.32 L3.27,-14.32 L6.26,-2.81 L9.31,-14.32 L12.40,-14.32 L15.32,-2.86 L18.28,-14.32 L21.19,-14.32 Z" />
                  <path transform="translate(106.83,107)" d="M0.54,-7.50 L0.54,-8.75 L3.04,-8.75 L3.04,-0.00 L1.66,-0.00 L1.66,-7.50 L0.54,-7.50 Z M4.74,-7.50 L4.74,-8.75 L7.24,-8.75 L7.24,-0.00 L5.86,-0.00 L5.86,-7.50 L4.74,-7.50 Z" />
                  <path transform="translate(123.97,104)" d="M21.19,-14.32 L16.75,-0.00 L13.63,-0.00 L10.74,-10.58 L7.85,-0.00 L4.73,-0.00 L0.26,-14.32 L3.27,-14.32 L6.26,-2.81 L9.31,-14.32 L12.40,-14.32 L15.32,-2.86 L18.28,-14.32 L21.19,-14.32 Z" />
                  <path transform="translate(145.12,107)" d="M0.54,-7.50 L0.54,-8.75 L3.04,-8.75 L3.04,-0.00 L1.66,-0.00 L1.66,-7.50 L0.54,-7.50 Z M5.68,-1.86 Q6.83,-2.86 7.49,-3.50 Q8.16,-4.14 8.60,-4.84 Q9.05,-5.53 9.05,-6.23 Q9.05,-6.95 8.71,-7.36 Q8.36,-7.76 7.63,-7.76 Q6.92,-7.76 6.53,-7.31 Q6.14,-6.86 6.12,-6.11 L4.80,-6.11 Q4.84,-7.48 5.62,-8.20 Q6.41,-8.93 7.62,-8.93 Q8.93,-8.93 9.67,-8.21 Q10.40,-7.49 10.40,-6.29 Q10.40,-5.42 9.97,-4.63 Q9.53,-3.83 8.92,-3.20 Q8.32,-2.57 7.38,-1.74 L6.84,-1.26 L10.64,-1.26 L10.64,-0.12 L4.81,-0.12 L4.81,-1.12 L5.68,-1.86 Z" />
                  <path transform="translate(84.35,128)" d="M21.19,-14.32 L16.75,-0.00 L13.63,-0.00 L10.74,-10.58 L7.85,-0.00 L4.73,-0.00 L0.26,-14.32 L3.27,-14.32 L6.26,-2.81 L9.31,-14.32 L12.40,-14.32 L15.32,-2.86 L18.28,-14.32 L21.19,-14.32 Z" />
                  <path transform="translate(105.44,131)" d="M1.48,-1.86 Q2.63,-2.86 3.29,-3.50 Q3.96,-4.14 4.40,-4.84 Q4.85,-5.53 4.85,-6.23 Q4.85,-6.95 4.51,-7.36 Q4.16,-7.76 3.43,-7.76 Q2.72,-7.76 2.33,-7.31 Q1.94,-6.86 1.92,-6.11 L0.60,-6.11 Q0.64,-7.48 1.42,-8.20 Q2.21,-8.93 3.42,-8.93 Q4.73,-8.93 5.47,-8.21 Q6.20,-7.49 6.20,-6.29 Q6.20,-5.42 5.77,-4.63 Q5.33,-3.83 4.72,-3.20 Q4.12,-2.57 3.18,-1.74 L2.64,-1.26 L6.44,-1.26 L6.44,-0.12 L0.61,-0.12 L0.61,-1.12 L1.48,-1.86 Z M7.46,-7.50 L7.46,-8.75 L9.96,-8.75 L9.96,-0.00 L8.58,-0.00 L8.58,-7.50 L7.46,-7.50 Z" />
                  <path transform="translate(122.64,128)" d="M21.19,-14.32 L16.75,-0.00 L13.63,-0.00 L10.74,-10.58 L7.85,-0.00 L4.73,-0.00 L0.26,-14.32 L3.27,-14.32 L6.26,-2.81 L9.31,-14.32 L12.40,-14.32 L15.32,-2.86 L18.28,-14.32 L21.19,-14.32 Z" />
                  <path transform="translate(143.73,131)" d="M1.48,-1.86 Q2.63,-2.86 3.29,-3.50 Q3.96,-4.14 4.40,-4.84 Q4.85,-5.53 4.85,-6.23 Q4.85,-6.95 4.51,-7.36 Q4.16,-7.76 3.43,-7.76 Q2.72,-7.76 2.33,-7.31 Q1.94,-6.86 1.92,-6.11 L0.60,-6.11 Q0.64,-7.48 1.42,-8.20 Q2.21,-8.93 3.42,-8.93 Q4.73,-8.93 5.47,-8.21 Q6.20,-7.49 6.20,-6.29 Q6.20,-5.42 5.77,-4.63 Q5.33,-3.83 4.72,-3.20 Q4.12,-2.57 3.18,-1.74 L2.64,-1.26 L6.44,-1.26 L6.44,-0.12 L0.61,-0.12 L0.61,-1.12 L1.48,-1.86 Z M8.40,-1.86 Q9.55,-2.86 10.22,-3.50 Q10.88,-4.14 11.33,-4.84 Q11.77,-5.53 11.77,-6.23 Q11.77,-6.95 11.43,-7.36 Q11.09,-7.76 10.36,-7.76 Q9.65,-7.76 9.26,-7.31 Q8.87,-6.86 8.84,-6.11 L7.52,-6.11 Q7.56,-7.48 8.35,-8.20 Q9.13,-8.93 10.34,-8.93 Q11.65,-8.93 12.39,-8.21 Q13.13,-7.49 13.13,-6.29 Q13.13,-5.42 12.69,-4.63 Q12.25,-3.83 11.65,-3.20 Q11.04,-2.57 10.10,-1.74 L9.56,-1.26 L13.37,-1.26 L13.37,-0.12 L7.54,-0.12 L7.54,-1.12 L8.40,-1.86 Z" />
                </g>
              </svg>
              <span class="flow-center-name">TOKENJAM</span>
            </div>
          </div>

          <!-- Products column -->
          <ul class="flow-products" id="flow-products">
            {products.map((p) => (
              <li
                class="flow-node flow-product"
                data-id={p.slug}
                style={`--product-accent: ${p.accent}; --product-accent-rgb: ${p.accentRgb};`}
              >
                <a href={`/products/${p.slug}`} class="flow-product-link">
                  <span class="flow-product-dot" aria-hidden="true"></span>
                  <span class="flow-product-name">{p.name}</span>
                  <span class="flow-product-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- SVG overlay drawn by JS -->
        <svg class="flow-svg" id="flow-svg" aria-hidden="true"></svg>

        <!-- Access channels strip -->
        <div class="flow-channels" aria-label="Recommendations land in your existing tools">
          <span class="flow-channels-label">Available via</span>
          <span class="flow-channel">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><rect x="1" y="2" width="10" height="8" rx="1"/><path d="M3 5l1.5 1L3 7"/><path d="M6 7.5h3"/></svg>
            CLI
          </span>
          <span class="flow-dot">·</span>
          <span class="flow-channel">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M2 4h8M2 6h8M2 8h6"/></svg>
            MCP
          </span>
          <span class="flow-dot">·</span>
          <span class="flow-channel">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M6 2v6M3 5l3 3 3-3M2 10h8"/></svg>
            Exported config
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- WORKS-WITH STRIP -->
  <section class="works-with">
    <p class="works-with-caption">
      Reads telemetry from every major agent runtime, framework, provider, and observability tool.
    </p>
    <div class="works-with-track" aria-hidden="true">
      <div class="works-with-row">
        {allIntegrations.map((name) => (
          <span class="works-with-pill">{name}</span>
        ))}
        {allIntegrations.map((name) => (
          <span class="works-with-pill" aria-hidden="true">{name}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- FOUR-PRODUCT SUMMARY -->
  <section class="products-grid-section">
    <header class="section-head">
      <h2 class="section-h2">Four analyzers. One install.</h2>
      <p class="section-lede">
        Each analyzer reads the same captured telemetry and surfaces a different shape of waste.
      </p>
    </header>

    <div class="products-grid">
      {products.map((p) => (
        <article
          class="product-card"
          style={`--product-accent: ${p.accent}; --product-accent-rgb: ${p.accentRgb};`}
        >
          <a
            class="product-card-overlay"
            href={`/products/${p.slug}`}
            aria-label={`Read more about ${p.name}`}
          ></a>
          <header class="product-card-head">
            <h3 class="product-card-name">{p.name}</h3>
            <p class="product-card-blurb">{p.blurb}</p>
          </header>
          <div class="terminal product-card-term">
            <div class="terminal-titlebar">
              <span class="dot dot-r"></span>
              <span class="dot dot-y"></span>
              <span class="dot dot-g"></span>
              <span class="terminal-title">tj optimize — {p.slug}</span>
            </div>
            <pre class="terminal-body product-card-body">{p.output.map((line) => (
              <span class={`tline t-${line.c}`}>{line.t || ' '}</span>
            ))}</pre>
          </div>
          <a class="product-card-link" href={`/products/${p.slug}`}>
            See how it works <span aria-hidden="true">→</span>
          </a>
        </article>
      ))}
    </div>

    <div class="products-cta-strip">
      <p>All four are in the open-source CLI. Install once, analyze everything.</p>
      <div class="products-cta-buttons">
        <a href="#install" class="btn-primary">Get started</a>
        <a href="https://github.com/metabuilder-labs/tokenjam" target="_blank" rel="noopener noreferrer" class="btn-secondary">GitHub</a>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="how">
    <header class="section-head">
      <h2 class="section-h2">How it works</h2>
    </header>
    <div class="how-grid">
      <div class="how-col">
        <h3 class="how-h3">Gathering Data</h3>
        <p>
          TokenJam reads from wherever your agent data lives. Direct OTel capture if you don't have an observability tool yet. Local log files if you're on Claude Code or Codex. Ingestion from Langfuse, Helicone, LangSmith, or Phoenix if you already have one of those running. The analyzers work the same way regardless of source.
        </p>
      </div>
      <div class="how-col">
        <h3 class="how-h3">Analyzing Data</h3>
        <p>
          Four analyzers, each grounded in published research and validated against your own data. Findings carry explicit confidence levels. TokenJam never claims a smaller model would have produced an identical answer; it shows the candidates with evidence, and you decide what to apply.
        </p>
      </div>
      <div class="how-col">
        <h3 class="how-h3">Optimizing Token Use</h3>
        <p>
          Recommendations land where you'll act on them. Run <code>tj optimize</code> in your terminal. Query TokenJam from inside Claude Code or any MCP-capable agent. Or export a routing config that drops into your existing Claude Code, LiteLLM, or framework setup.
        </p>
      </div>
    </div>
  </section>

  {/* CLOUD EARLY-ACCESS TEASER — hidden for now; restore when Cloud copy/launch is ready.
  <section class="cloud-teaser">
    <div class="cloud-teaser-inner">
      <span class="cloud-eyebrow">TokenJam Cloud</span>
      <h2 class="cloud-h2">Hosted, multi-user, governed. Same four products, run across your team's agents.</h2>
      <p class="cloud-body">
        Cloud aggregates the analyzers across every agent your team runs. Recommendations land in a shared dashboard instead of N developers each running <code>tj optimize</code> locally. Policies for routing, budgets, and sensitive-action rules are defined once and applied across the fleet.
      </p>
      <p class="cloud-body">
        Replay validation runs against a team-pooled budget. A recommendation validated once benefits everyone who works on similar code. The daemon, the ingestion pipelines, the analyzer infrastructure — none of it is your team's problem to maintain.
      </p>
      <a class="btn-primary btn-lg" href="/cloud">Request early access →</a>
    </div>
  </section>
  */}

  <!-- INSTALL -->
  <section id="install" class="install-section">
    <header class="section-head">
      <h2 class="section-h2">Install</h2>
      <p class="section-lede">Three commands. Local. No signup.</p>
    </header>

    <div class="install-card">
      <div class="terminal install-term">
        <div class="terminal-titlebar">
          <span class="dot dot-r"></span>
          <span class="dot dot-y"></span>
          <span class="dot dot-g"></span>
          <span class="terminal-title">install</span>
        </div>
        <div class="terminal-body install-body">
          {installLines.map((cmd) => (
            <span class="tline"><span class="t-prompt">$ </span><span class="t-cmd">{cmd}</span></span>
          ))}
        </div>
      </div>
      <div class="install-ctas">
        <button class="btn-primary" id="install-copy-btn" data-cmd={installJoined} type="button">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="4" y="4" width="8" height="8" rx="1.5"/><path d="M2 10V3a1 1 0 011-1h7"/></svg>
          <span id="install-copy-label">Copy install commands</span>
        </button>
        <a class="btn-secondary" href="https://github.com/metabuilder-labs/tokenjam" target="_blank" rel="noopener noreferrer">
